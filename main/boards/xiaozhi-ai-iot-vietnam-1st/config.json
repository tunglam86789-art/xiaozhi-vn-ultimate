
{
    "target": "esp32s3",
    "builds": [
        {
            "name": "xiaozhi-ai-iot-vietnam-1st",
            "sdkconfig_append": [
                "CONFIG_PARTITION_TABLE_CUSTOM_FILENAME=\"partitions/v2/16m_logo.csv\"",
                "CONFIG_SD_CARD_SPI_INTERFACE=n",
                "CONFIG_FATFS_LFN_HEAP=y",
                "CONFIG_FATFS_API_ENCODING_UTF_8=y",
                "CONFIG_FATFS_FS_LOCK=5",
                "CONFIG_LOG_DEFAULT_LEVEL_NONE=y",
                "CONFIG_USE_ACOUSTIC_WIFI_PROVISIONING=y",
                "CONFIG_USE_DEVICE_AEC=y"
            ]
        }
    ]
}